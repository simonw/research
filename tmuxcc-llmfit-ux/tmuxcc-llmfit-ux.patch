+    pub fn filter_char(&mut self, c: char) {
+        self.filter_query.push(c);
+    }
+
+    /// Remove the last character from the filter query
+    pub fn filter_backspace(&mut self) {
+        self.filter_query.pop();
+    }
+
+    /// Clear all active filters and exit filter mode
+    pub fn clear_filter(&mut self) {
+        self.filter_query.clear();
+        self.filter_status = StatusFilter::All;
+        self.filter_agent_type = AgentTypeFilter::All;
+        self.filter_active = false;
+    }
+
+    /// Cycle through status filter chips (like llmfit's FitFilter cycling)
+    pub fn cycle_status_filter(&mut self) {
+        self.filter_status = self.filter_status.next();
+    }
+
+    /// Cycle through agent-type filter chips (like llmfit's provider filter)
+    pub fn cycle_type_filter(&mut self) {
+        self.filter_agent_type = self.filter_agent_type.next();
+    }
+
+    /// Returns true if any filter is currently active
+    pub fn has_active_filter(&self) -> bool {
+        !self.filter_query.is_empty()
+            || self.filter_status != StatusFilter::All
+            || self.filter_agent_type != AgentTypeFilter::All
+    }
+
+    /// Returns true if the given agent matches the current filters.
+    /// Used by the agent tree to dim non-matching agents.
+    pub fn agent_matches_filter(&self, agent: &MonitoredAgent) -> bool {
+        // Text query: case-insensitive match against session, window name, working dir
+        if !self.filter_query.is_empty() {
+            let q = self.filter_query.to_lowercase();
+            let haystack = format!(
+                "{} {} {} {}",
+                agent.session,
+                agent.window_name,
+                agent.agent_type.display_name(),
+                agent.abbreviated_path()
+            )
+            .to_lowercase();
+            if !haystack.contains(&q) {
+                return false;
+            }
+        }
+
+        // Status filter chip
+        match self.filter_status {
+            StatusFilter::All => {}
+            StatusFilter::Waiting => {
+                if !matches!(agent.status, AgentStatus::AwaitingApproval { .. }) {
+                    return false;
+                }
+            }
+            StatusFilter::Working => {
+                if !matches!(agent.status, AgentStatus::Processing { .. }) {
+                    return false;
+                }
+            }
+            StatusFilter::Idle => {
+                if !matches!(agent.status, AgentStatus::Idle) {
+                    return false;
+                }
+            }
+            StatusFilter::Error => {
+                if !matches!(agent.status, AgentStatus::Error { .. }) {
+                    return false;
+                }
+            }
+        }
+
+        // Agent type filter chip
+        match self.filter_agent_type {
+            AgentTypeFilter::All => {}
+            AgentTypeFilter::ClaudeCode => {
+                if agent.agent_type != AgentType::ClaudeCode {
+                    return false;
+                }
+            }
+            AgentTypeFilter::OpenCode => {
+                if agent.agent_type != AgentType::OpenCode {
+                    return false;
+                }
+            }
+            AgentTypeFilter::CodexCli => {
+                if agent.agent_type != AgentType::CodexCli {
+                    return false;
+                }
+            }
+            AgentTypeFilter::GeminiCli => {
+                if agent.agent_type != AgentType::GeminiCli {
+                    return false;
+                }
+            }
+        }
+
+        true
+    }
+
+    /// Count of agents matching the current filters
+    pub fn filtered_agent_count(&self) -> usize {
+        if !self.has_active_filter() {
+            return self.agents.root_agents.len();
+        }
+        self.agents
+            .root_agents
+            .iter()
+            .filter(|a| self.agent_matches_filter(a))
+            .count()
+    }
 }
 
