+/// Filter by agent status (llmfit-inspired: like FitFilter cycling)
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Default)]
+pub enum StatusFilter {
+    #[default]
+    All,
+    Waiting,
+    Working,
+    Idle,
+    Error,
+}
+
+impl StatusFilter {
+    pub fn next(self) -> Self {
+        match self {
+            StatusFilter::All => StatusFilter::Waiting,
+            StatusFilter::Waiting => StatusFilter::Working,
+            StatusFilter::Working => StatusFilter::Idle,
+            StatusFilter::Idle => StatusFilter::Error,
+            StatusFilter::Error => StatusFilter::All,
+        }
+    }
+
+    pub fn label(self) -> &'static str {
+        match self {
+            StatusFilter::All => "All",
+            StatusFilter::Waiting => "⚠ Waiting",
+            StatusFilter::Working => "● Working",
+            StatusFilter::Idle => "● Idle",
+            StatusFilter::Error => "✗ Error",
+        }
+    }
+}
+
+/// Filter by agent type (llmfit-inspired: like provider filter)
+#[derive(Debug, Clone, Copy, PartialEq, Eq, Default)]
+pub enum AgentTypeFilter {
+    #[default]
+    All,
+    ClaudeCode,
+    OpenCode,
+    CodexCli,
+    GeminiCli,
+}
+
+impl AgentTypeFilter {
+    pub fn next(self) -> Self {
+        match self {
+            AgentTypeFilter::All => AgentTypeFilter::ClaudeCode,
+            AgentTypeFilter::ClaudeCode => AgentTypeFilter::OpenCode,
+            AgentTypeFilter::OpenCode => AgentTypeFilter::CodexCli,
+            AgentTypeFilter::CodexCli => AgentTypeFilter::GeminiCli,
+            AgentTypeFilter::GeminiCli => AgentTypeFilter::All,
+        }
+    }
+
+    pub fn label(self) -> &'static str {
+        match self {
+            AgentTypeFilter::All => "All",
+            AgentTypeFilter::ClaudeCode => "Claude",
+            AgentTypeFilter::OpenCode => "Open",
+            AgentTypeFilter::CodexCli => "Codex",
+            AgentTypeFilter::GeminiCli => "Gemini",
+        }
+    }
+}
+
